# VM images and snapshots (large binary files)
# images/ and traces/ are typically symlinks to a large-disk location;
# without the trailing slash the pattern ignores both directories and symlinks.
images
snapshots/*
!snapshots/README.md

# Raw and converted trace data
dump/*
!dump/README.md
traces

# Built binaries
plugin/champsim_tracer.so
plugin/trace_inspector
plugin/trace_filter
converter/raw2champsim

# Zydis (fetched by converter/Makefile)
converter/zydis/

# ChampSim build artifacts
champsim/obj/
champsim/bin/

# Editor / IDE
*.swp
*.swo
*~
.vscode/
.claude/
.idea/
